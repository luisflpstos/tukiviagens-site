  "image_generation_prompt": {
    "prompt": "Create a modern, playful Brazilian travel agency landing page for a fictional brand called Tuki Viagens. Use a deep purple and orange visual identity, a 3D toucan mascot, rounded cards, soft shadows, tropical resort imagery, floating badges, orange sparkle decorations, and a premium but fun family-travel feeling. The page should include a hero section, trust badges, destination categories, hotel/resort cards, benefits section, mascot story section, testimonials, partner badges, final CTA and dark purple footer. Use strong rounded typography, large bold headlines, white space, organic wave dividers, radial gradient glows and pill-shaped buttons.",
    "negative_prompt": "avoid flat corporate design, avoid sharp corners, avoid dark unreadable text, avoid generic stock layout, avoid excessive clutter, avoid monochrome palette"
  }
