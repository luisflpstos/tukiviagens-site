---
import BaseLayout from './BaseLayout.astro';
import WhatsAppButton from '../components/common/WhatsAppButton.astro';

interface Props {
	title: string;
	description: string;
	path: string;
	noindex?: boolean;
	whatsapp: string;
	campaign?: string;
	whatsappMessage?: string;
}

const { title, description, path, noindex = true, whatsapp, campaign, whatsappMessage } = Astro.props;
---

<BaseLayout
	title={title}
	description={description}
	path={path}
	noindex={noindex}
	showHeader={false}
	showFooter={false}
>
	<slot />
	<WhatsAppButton
		phone={whatsapp}
		message={whatsappMessage}
		campaign={campaign}
		fixed
		label=""
		class="!px-4"
	/>
</BaseLayout>
