---
import BaseLayout from './BaseLayout.astro';
import Container from '../components/common/Container.astro';
import Button from '../components/common/Button.astro';
import BenefitsList from '../components/sections/BenefitsList.astro';
import LeadCaptureSection from '../components/sections/LeadCaptureSection.astro';
import { formatLocation } from '../lib/formatters';
import { buildWhatsAppUrl } from '../lib/seo';

interface Props {
	title: string;
	description: string;
	path: string;
	headline: string;
	estado: string;
	highlights: string[];
	whatsapp: string;
	cta: string;
}

const { title, description, path, headline, estado, highlights, whatsapp, cta } = Astro.props;
---

<BaseLayout title={title} description={description} path={path}>
	<section class="tuki-gradient-purple section-padding text-white">
		<Container>
			<p class="tuki-eyebrow-light">Destino</p>
			<h1 class="tuki-type-display mt-2">{headline}</h1>
			<p class="tuki-type-body tuki-type-inverse mt-2 text-white/85">{estado}</p>
			<Button
				href={buildWhatsAppUrl(whatsapp, `Olá! Gostaria de planejar uma viagem para ${title}.`)}
				variant="primary"
				size="lg"
				class="mt-8"
			>
				{cta}
			</Button>
		</Container>
	</section>

	<article class="section-padding">
		<Container size="narrow">
			<div class="content-markdown max-w-none">
				<slot />
			</div>
		</Container>
	</article>

	<BenefitsList items={highlights} title="Destaques" />
	<LeadCaptureSection formId="destino-lead-form" destination={title} title="Planeje sua viagem" />
</BaseLayout>
