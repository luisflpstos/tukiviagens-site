---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/common/Container.astro';
import LeadForm from '../components/common/LeadForm.astro';
import WhatsAppButton from '../components/common/WhatsAppButton.astro';
import { SITE } from '../lib/constants';
import { buildWhatsAppUrl } from '../lib/seo';
---

<BaseLayout
	title="Contato"
	description="Entre em contato com a Tuki Viagens. Atendimento humano para planejar sua viagem com hotéis e resorts selecionados."
	path="/contato"
>
	<section class="tuki-gradient-purple section-padding text-white">
		<Container>
			<h1 class="tuki-type-display">Fale com a Tuki</h1>
			<p class="tuki-type-lead tuki-type-inverse tuki-measure mt-4 text-white/90">
				Estamos prontos para ajudar você a encontrar o hotel ou resort ideal para sua próxima viagem.
			</p>
		</Container>
	</section>

	<section class="section-padding">
		<Container>
			<div class="grid gap-12 lg:grid-cols-2">
				<div>
					<h2 class="tuki-type-headline text-tuki-ink">Canais de atendimento</h2>
					<ul class="tuki-type-body mt-6 space-y-4 text-tuki-muted">
						<li>
							<strong>Endereço:</strong> {SITE.location}
						</li>
						<li>
							<strong>Telefone:</strong>
							<a href={`tel:+${SITE.phone}`} class="text-tuki-purple hover:underline">
								{SITE.phoneDisplay}
							</a>
						</li>
						<li>
							<strong>E-mail:</strong>
							<a href={`mailto:${SITE.email}`} class="text-tuki-purple hover:underline">
								{SITE.email}
							</a>
						</li>
						<li>
							<strong>WhatsApp:</strong>
							<a
								href={buildWhatsAppUrl(SITE.phone, 'Olá! Gostaria de falar com a Tuki Viagens.')}
								class="text-tuki-purple hover:underline"
								target="_blank"
								rel="noopener noreferrer"
							>
								{SITE.whatsappDisplay}
							</a>
						</li>
						<li>
							<strong>CNPJ:</strong> {SITE.cnpj}
						</li>
					</ul>
					<div class="mt-8">
						<WhatsAppButton
							phone={SITE.phone}
							message="Olá! Gostaria de falar com a Tuki Viagens."
							label="Chamar no WhatsApp"
						/>
					</div>
				</div>

				<div class="tuki-surface-panel">
					<h2 class="tuki-type-headline text-tuki-ink">Ou preencha o formulário</h2>
					<p class="tuki-type-body mt-2 text-tuki-muted">Retornamos o mais rápido possível.</p>
					<div class="mt-8">
						<LeadForm formId="contato-lead-form" submitLabel="Enviar mensagem" />
					</div>
				</div>
			</div>
		</Container>
	</section>
</BaseLayout>
