---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import MarqueeStrip from '../components/sections/MarqueeStrip.astro';
import DestinationsGrid from '../components/sections/DestinationsGrid.astro';
import HotelsGrid from '../components/sections/HotelsGrid.astro';
import WhyTuki from '../components/sections/WhyTuki.astro';
import MascotSection from '../components/sections/MascotSection.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import PartnersStrip from '../components/sections/PartnersStrip.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import WhatsAppFab from '../components/common/WhatsAppFab.astro';
import { HOME_FEATURED_PROPERTIES, SITE } from '../lib/constants';

const properties = HOME_FEATURED_PROPERTIES.map((item) => ({
	id: item.id,
	title: item.title,
	cidade: item.cidade,
	estado: item.estado,
	categoria: item.categoria,
	href: item.href,
	priceFrom: item.priceFrom,
}));
---

<BaseLayout
	title={SITE.name}
	description="Viagens com curadoria, atendimento humano e pagamento seguro. Hotéis, resorts e destinos selecionados a dedo pela Tuki Viagens."
	path="/"
>
	<div id="conteudo">
	<script is:inline>
		try {
			document.documentElement.classList.add('tuki-motion-ready');
			if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
				document.documentElement.classList.add('tuki-reduced-motion');
			}
		} catch {}
	</script>
	<Hero />
	<MarqueeStrip />
	<DestinationsGrid />
	<HotelsGrid items={properties} />
	<WhyTuki />
	<MascotSection />
	<Testimonials />
	<PartnersStrip />
	<CtaSection />
	<WhatsAppFab />
	</div>
	<script>
		import { initHomeMotion } from '../scripts/home-motion.ts';
		initHomeMotion();
	</script>
</BaseLayout>
