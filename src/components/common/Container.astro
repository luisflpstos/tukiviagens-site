---
interface Props {
	class?: string;
	size?: 'default' | 'narrow' | 'wide';
}

const { class: className = '', size = 'default' } = Astro.props;

const sizes = {
	default: 'max-w-6xl',
	narrow: 'max-w-3xl',
	wide: 'max-w-7xl',
};
---

<div class:list={['mx-auto w-full px-4 sm:px-6 lg:px-8', sizes[size], className]}>
	<slot />
</div>
