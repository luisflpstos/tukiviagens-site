---
import { BRAND } from '../../lib/constants';

interface Props {
	variant?: 'white' | 'color' | 'dark';
	class?: string;
	height?: number;
}

const { variant = 'white', class: className = '', height = 40 } = Astro.props;

const src = {
	white: BRAND.logoWhite,
	color: BRAND.logoColor,
	dark: BRAND.logoDark,
}[variant];
---

<a href="/" class:list={['inline-flex shrink-0 items-center', className]} aria-label={BRAND.name}>
	<img
		src={src}
		alt={BRAND.name}
		height={height}
		width={Math.round(height * 1.5)}
		class="h-auto w-auto max-h-[var(--logo-height)]"
		style={`--logo-height: ${height}px`}
		loading="eager"
		decoding="async"
	/>
</a>
