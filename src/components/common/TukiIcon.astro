---
interface Props {
	src: string;
	alt: string;
	size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl';
	class?: string;
	decorative?: boolean;
}

const { src, alt, size = 'md', class: className = '', decorative = false } = Astro.props;

const sizes = {
	xs: 'h-8 w-8',
	sm: 'h-11 w-11',
	md: 'h-15 w-15',
	lg: 'h-19 w-19',
	xl: 'h-21 w-21',
	'2xl': 'h-38 w-38',
};

const dimensions = {
	xs: 32,
	sm: 44,
	md: 60,
	lg: 76,
	xl: 84,
	'2xl': 152,
};
---

<img
	src={src}
	alt={decorative ? '' : alt}
	aria-hidden={decorative ? 'true' : undefined}
	class:list={['tuki-brand-icon object-contain', sizes[size], className]}
	width={dimensions[size]}
	height={dimensions[size]}
	loading="lazy"
	decoding="async"
/>
