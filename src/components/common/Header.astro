---
import { SITE, NAV_LINKS } from '../../lib/constants';
import Button from './Button.astro';
---

<header class="sticky top-0 z-50 bg-tuki-purple/95 backdrop-blur-sm">
	<div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
		<a href="/" class="text-2xl font-bold text-white">
			{SITE.name.split(' ')[0]}
		</a>

		<nav class="hidden items-center gap-8 md:flex" aria-label="Principal">
			{
				NAV_LINKS.map((link) => (
					<a href={link.href} class="text-sm font-medium text-white/90 transition hover:text-white">
						{link.label}
					</a>
				))
			}
		</nav>

		<Button href="/contato" variant="primary" size="sm" class="hidden md:inline-flex">
			Começar
		</Button>

		<details class="relative md:hidden">
			<summary class="cursor-pointer list-none rounded-lg p-2 text-white" aria-label="Abrir menu">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</summary>
			<div class="absolute right-0 mt-2 w-56 rounded-xl bg-white p-4 shadow-xl">
				{
					NAV_LINKS.map((link) => (
						<a href={link.href} class="block py-2 text-sm font-medium text-gray-700 hover:text-tuki-purple">
							{link.label}
						</a>
					))
				}
				<Button href="/contato" variant="primary" size="sm" class="mt-3 w-full">
					Começar
				</Button>
			</div>
		</details>
	</div>
</header>
