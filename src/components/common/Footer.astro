---
import { SITE, FOOTER_DESTINATIONS, BRAND } from '../../lib/constants';
import { buildWhatsAppUrl } from '../../lib/seo';
import Logo from './Logo.astro';

const whatsappHref = buildWhatsAppUrl(SITE.phone, 'Olá! Gostaria de saber mais sobre a Tuki Viagens.');
---

<footer class="bg-tuki-purple-dark text-white">
	<div class="mx-auto max-w-[980px] px-4 py-16 sm:px-6">
		<div class="grid gap-10 md:grid-cols-4">
			<div class="md:col-span-1">
				<Logo variant="white" height={44} />
				<p class="mt-4 text-sm leading-relaxed text-white/75">
					Viagens com curadoria, atendimento humano e a leveza que você merece.
				</p>
				<img
					src={BRAND.cadastur}
					alt="Selo Cadastur — agência de turismo cadastrada"
					class="mt-6 h-16 w-auto"
					width={120}
					height={48}
					loading="lazy"
					decoding="async"
				/>
			</div>

			<div>
				<h3 class="font-semibold">Destinos</h3>
				<ul class="mt-4 space-y-2 text-sm text-white/70">
					{
						FOOTER_DESTINATIONS.map((dest) => (
							<li>
								<a href={dest.href} class="transition hover:text-white">
									{dest.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div>
				<h3 class="font-semibold">Tuki</h3>
				<ul class="mt-4 space-y-2 text-sm text-white/70">
					<li><a href="/agencia-de-viagens/" class="transition hover:text-white">Agência de viagens</a></li>
					<li><a href="/#por-que-tuki" class="transition hover:text-white">Por que Tuki</a></li>
					<li><a href="/#depoimentos" class="transition hover:text-white">Depoimentos</a></li>
					<li><a href="/contato" class="transition hover:text-white">Contato</a></li>
				</ul>
			</div>

			<div>
				<h3 class="font-semibold">Contato</h3>
				<address class="mt-4 space-y-2 text-sm not-italic text-white/70">
					<p>{SITE.location}</p>
					<p>
						<a href={`tel:+${SITE.phone}`} class="transition hover:text-white">
							{SITE.phoneDisplay}
						</a>
					</p>
					<p>
						<a href={`mailto:${SITE.email}`} class="transition hover:text-white">
							{SITE.email}
						</a>
					</p>
					<p>
						WhatsApp:{' '}
						<a href={whatsappHref} class="transition hover:text-white" target="_blank" rel="noopener noreferrer">
							{SITE.whatsappDisplay}
						</a>
					</p>
				</address>
			</div>
		</div>

		<div
			class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-8 text-sm text-white/50 sm:flex-row sm:items-center"
		>
			<div>
				<p>&copy; {new Date().getFullYear()} {SITE.name}. Todos os direitos reservados.</p>
				<p class="mt-1 text-xs text-white/40">{SITE.cadastro}</p>
			</div>
		</div>
	</div>
</footer>
