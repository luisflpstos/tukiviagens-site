---
import { SITE, FOOTER_DESTINATIONS } from '../../lib/constants';
import { buildWhatsAppUrl } from '../../lib/seo';
import Logo from './Logo.astro';
---

<footer class="bg-tuki-purple-dark text-white">
	<div class="mx-auto max-w-[980px] px-4 py-16 sm:px-6">
		<div class="grid gap-10 md:grid-cols-4">
			<div class="md:col-span-1">
				<Logo variant="white" height={44} />
				<p class="mt-4 text-sm leading-relaxed text-white/75">
					Viagens com curadoria, atendimento humano e a leveza que você merece.
				</p>
			</div>

			<div>
				<h3 class="font-semibold">Destinos</h3>
				<ul class="mt-4 space-y-2 text-sm text-white/70">
					{
						FOOTER_DESTINATIONS.map((dest) => (
							<li>
								<a href={dest.href} class="transition hover:text-white">
									{dest.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div>
				<h3 class="font-semibold">Tuki</h3>
				<ul class="mt-4 space-y-2 text-sm text-white/70">
					<li><a href="/agencia-de-viagens/" class="transition hover:text-white">Agência de viagens</a></li>
					<li><a href="/#por-que-tuki" class="transition hover:text-white">Por que Tuki</a></li>
					<li><a href="/#depoimentos" class="transition hover:text-white">Depoimentos</a></li>
					<li><a href="/contato" class="transition hover:text-white">Contato</a></li>
				</ul>
			</div>

			<div>
				<h3 class="font-semibold">Contato</h3>
				<ul class="mt-4 space-y-2 text-sm text-white/70">
					<li>{SITE.phoneDisplay}</li>
					<li>
						<a href={`mailto:${SITE.email}`} class="transition hover:text-white">{SITE.email}</a>
					</li>
					<li>
						<a
							href={buildWhatsAppUrl(SITE.phone, 'Olá! Gostaria de saber mais sobre a Tuki Viagens.')}
							class="transition hover:text-white"
							target="_blank"
							rel="noopener noreferrer"
						>
							WhatsApp
						</a>
					</li>
				</ul>
			</div>
		</div>

		<div
			class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 text-sm text-white/50 sm:flex-row"
		>
			<p>&copy; {new Date().getFullYear()} {SITE.name}. Todos os direitos reservados.</p>
			<div class="flex items-center gap-3">
				<a
					href="#"
					class="flex h-9 w-9 items-center justify-center rounded-full border border-white/25 transition hover:bg-white/10"
					aria-label="Instagram"
				>
					<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path
							d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
						></path>
					</svg>
				</a>
				<a
					href="#"
					class="flex h-9 w-9 items-center justify-center rounded-full border border-white/25 transition hover:bg-white/10"
					aria-label="Facebook"
				>
					<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path
							d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
						></path>
					</svg>
				</a>
			</div>
		</div>
	</div>
</footer>
