---
import Container from '../common/Container.astro';
import { HOME_DESTINATIONS } from '../../lib/constants';
---

<section id="destinos" class="section-padding bg-white">
	<Container>
		<div class="flex flex-wrap items-end justify-between gap-4">
			<h2 class="text-3xl font-bold text-gray-900 md:text-4xl">Para onde o Tuki te leva hoje?</h2>
			<a href="/destinos/olimpia" class="font-semibold text-tuki-purple hover:underline">
				Ver catálogo completo →
			</a>
		</div>

		<div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
			{
				HOME_DESTINATIONS.map((dest) => (
					<a
						href={dest.slug === 'olimpia' ? '/destinos/olimpia' : '/#destinos'}
						class="group flex flex-col items-center rounded-2xl bg-gray-50 p-6 text-center transition hover:bg-tuki-purple/5"
					>
						<span class="text-4xl">{dest.emoji}</span>
						<span class="mt-3 text-sm font-semibold text-gray-800 group-hover:text-tuki-purple">
							{dest.name}
						</span>
					</a>
				))
			}
		</div>
	</Container>
</section>
