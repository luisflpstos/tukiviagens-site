---
import Container from '../common/Container.astro';
import TukiIcon from '../common/TukiIcon.astro';
import { HOME_DESTINATIONS } from '../../lib/constants';
---

<section id="destinos" class="section-padding bg-white">
	<Container size="reference">
		<div class="flex flex-wrap items-end justify-between gap-6">
			<div class="max-w-2xl">
				<h2 class="text-3xl font-extrabold tracking-[-0.03em] text-tuki-ink md:text-4xl">
					Para onde o Tuki te <span class="text-tuki-orange">leva</span> hoje?
				</h2>
			</div>
			<a
				href="/pacotes-de-viagem-brasil/"
				class="inline-flex items-center gap-1 text-sm font-bold text-tuki-purple transition hover:text-tuki-purple-dark"
			>
				Ver pacotes no Brasil
				<span aria-hidden="true">→</span>
			</a>
		</div>

		<div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6" data-tuki-reveal>
			{
				HOME_DESTINATIONS.map((dest, index) => (
					<a href={dest.href} class="tuki-dest-card tuki-stagger-item group" style={`--i: ${index}`}>
						<div class="tuki-dest-icon">
							<TukiIcon src={dest.icon} alt={dest.iconAlt} size="lg" />
						</div>
						<span class="text-xs font-bold text-tuki-ink transition group-hover:text-tuki-purple md:text-sm">
							{dest.name}
						</span>
					</a>
				))
			}
		</div>
	</Container>
</section>
