---
import Container from '../common/Container.astro';
import Button from '../common/Button.astro';
import SectionEyebrow from '../common/SectionEyebrow.astro';
import { formatLocation } from '../../lib/formatters';
import { HOTELS_DESCRIPTION } from '../../lib/constants';

interface Property {
	id: string;
	title: string;
	cidade: string;
	estado: string;
	categoria: string;
	href: string;
	price?: string;
	image?: string;
}

interface Props {
	items: Property[];
	title?: string;
}

const { items, title = 'Hotéis e resorts selecionados a dedo.' } = Astro.props;

const tagColors = ['bg-tuki-orange-dark', 'bg-tuki-orange', 'bg-tuki-purple'] as const;
---

<section id="hoteis" class="section-padding tuki-section-lavender">
	<Container size="reference">
		<div class="max-w-3xl">
			<SectionEyebrow label="Curadoria Tuki" class="mb-3" />
			<h2 class="text-3xl font-extrabold tracking-[-0.03em] text-tuki-ink md:text-4xl">{title}</h2>
			<p class="mt-4 text-base leading-relaxed text-tuki-muted">{HOTELS_DESCRIPTION}</p>
		</div>

		<div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{
				items.map((item, index) => (
					<article class="tuki-card-ref group overflow-hidden bg-white transition hover:-translate-y-1">
						<div class="relative h-52 overflow-hidden bg-gradient-to-br from-tuki-purple/20 to-tuki-orange/15">
							{
								item.image ? (
									<img
										src={item.image}
										alt=""
										class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
										loading="lazy"
										decoding="async"
									/>
								) : (
									<div class="flex h-full items-center justify-center text-5xl" aria-hidden="true">
										🏨
									</div>
								)
							}
							<div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-tuki-ink/50 to-transparent"></div>
							<span
								class:list={[
									'absolute left-3 top-3 rounded-full px-2.5 py-1 text-[10px] font-bold text-white uppercase',
									tagColors[index % tagColors.length],
								]}
							>
								{item.categoria}
							</span>
							<span class="absolute right-3 top-3 flex items-center gap-1 rounded-full bg-white/95 px-2 py-1 text-[10px] font-bold text-tuki-ink">
								<span class="text-tuki-orange" aria-hidden="true">★</span> 4.9
							</span>
							<span class="absolute bottom-3 left-3 text-xs font-semibold text-white">
								{formatLocation(item.cidade, item.estado)}
							</span>
						</div>
						<div class="p-5">
							<h3 class="text-lg font-bold text-tuki-ink">{item.title}</h3>
							{
								item.price && (
									<p class="mt-2 text-sm text-tuki-muted">
										A partir de <span class="text-xl font-extrabold text-tuki-orange">{item.price}</span>
									</p>
								)
							}
							<Button href={item.href} variant="dark" size="sm" class="mt-4 w-full">
								Reservar
							</Button>
						</div>
					</article>
				))
			}
		</div>
	</Container>
</section>
