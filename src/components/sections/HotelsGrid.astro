---
import Container from '../common/Container.astro';
import Button from '../common/Button.astro';
import { formatLocation } from '../../lib/formatters';

interface Property {
	id: string;
	title: string;
	cidade: string;
	estado: string;
	categoria: string;
	href: string;
	price?: string;
}

interface Props {
	items: Property[];
	title?: string;
}

const { items, title = 'Hotéis e resorts selecionados a dedo.' } = Astro.props;
---

<section id="hoteis" class="section-padding bg-gray-50">
	<Container>
		<h2 class="text-3xl font-bold text-gray-900 md:text-4xl">{title}</h2>

		<div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{
				items.map((item) => (
					<article class="overflow-hidden rounded-2xl bg-white shadow-sm transition hover:shadow-md">
						<div class="relative flex h-48 items-center justify-center bg-gradient-to-br from-tuki-purple/20 to-tuki-orange/20">
							<span class="text-5xl">🏨</span>
							<span class="absolute left-3 top-3 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-gray-700">
								{formatLocation(item.cidade, item.estado)}
							</span>
						</div>
						<div class="p-5">
							<p class="text-xs font-medium uppercase tracking-wide text-tuki-purple">{item.categoria}</p>
							<h3 class="mt-1 text-lg font-bold text-gray-900">{item.title}</h3>
							{
								item.price && (
									<p class="mt-2 text-xl font-bold text-tuki-orange">{item.price}</p>
								)
							}
							<Button href={item.href} variant="secondary" size="sm" class="mt-4 w-full">
								Reservar
							</Button>
						</div>
					</article>
				))
			}
		</div>
	</Container>
</section>
