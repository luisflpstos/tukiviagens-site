---
import Container from '../common/Container.astro';
import Button from '../common/Button.astro';
import { formatLocation } from '../../lib/formatters';
import { HOTELS_DESCRIPTION, HOTEL_FALLBACK_IMAGES, HOTELS_PRICE_NOTE, SITE } from '../../lib/constants';
import { buildWhatsAppUrl } from '../../lib/seo';

interface Property {
	id: string;
	title: string;
	cidade: string;
	estado: string;
	categoria: string;
	href: string;
	priceFrom?: string;
	image?: string;
}

interface Props {
	items: Property[];
	title?: string;
}

const { items, title = 'Hotéis e resorts selecionados a dedo.' } = Astro.props;

const tagColors = ['bg-tuki-orange-dark', 'bg-tuki-orange', 'bg-tuki-purple'] as const;

function resolveHotelImage(image: string | undefined, index: number) {
	if (image && !image.includes('placeholder')) return image;
	return HOTEL_FALLBACK_IMAGES[index % HOTEL_FALLBACK_IMAGES.length];
}
---

<section id="hoteis" class="section-padding tuki-section-lavender">
	<Container size="reference">
		<div class="max-w-3xl">
			<h2 class="tuki-type-headline text-tuki-ink">{title}</h2>
			<p class="tuki-type-body tuki-measure mt-4 text-tuki-muted">{HOTELS_DESCRIPTION}</p>
		</div>

		<div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-tuki-reveal>
			{
				items.map((item, index) => {
					const imageSrc = resolveHotelImage(item.image, index);
					const quoteMessage = `Olá! Quero cotar o ${item.title} com a Tuki.`;
					const quoteHref = buildWhatsAppUrl(SITE.phone, quoteMessage);
					return (
						<article
							class="tuki-card-ref tuki-stagger-item group overflow-hidden bg-white transition hover:-translate-y-1 hover:shadow-md"
							style={`--i: ${index}`}
						>
							<a href={item.href} class="block">
								<div class="relative h-52 overflow-hidden bg-gradient-to-br from-tuki-purple/20 to-tuki-orange/15">
									<img
										src={imageSrc}
										alt={`Foto de ${item.title}`}
										class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
										loading="lazy"
										decoding="async"
										width={600}
										height={400}
									/>
									<div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-tuki-ink/50 to-transparent"></div>
									<span
										class:list={[
											'absolute left-3 top-3 rounded-full px-2.5 py-1 tuki-type-caption font-bold text-white uppercase',
											tagColors[index % tagColors.length],
										]}
									>
										{item.categoria}
									</span>
									<span class="absolute right-3 top-3 rounded-full bg-tuki-purple px-2 py-1 tuki-type-caption font-bold text-white">
										Escolha Tuki
									</span>
									<span class="absolute bottom-3 left-3 tuki-type-caption font-semibold text-white">
										{formatLocation(item.cidade, item.estado)}
									</span>
								</div>
							</a>
							<div class="p-5">
								<h3 class="tuki-type-title text-tuki-ink">
									<a href={item.href} class="transition hover:text-tuki-purple">
										{item.title}
									</a>
								</h3>
								{
									item.priceFrom && (
										<p class="tuki-type-small mt-2 text-tuki-muted">
											A partir de{' '}
											<span class="tuki-tabular-nums tuki-type-title font-extrabold text-tuki-orange">{item.priceFrom}</span>
											<span class="tuki-type-caption mt-1 block text-tuki-muted">{HOTELS_PRICE_NOTE}</span>
										</p>
									)
								}
								<Button
									href={quoteHref}
									variant="dark"
									size="sm"
									class="mt-4 w-full"
									target="_blank"
									rel="noopener noreferrer"
								>
									Cotar com consultor
								</Button>
							</div>
						</article>
					);
				})
			}
		</div>
	</Container>
</section>
