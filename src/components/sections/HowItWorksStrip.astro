---
import Container from '../common/Container.astro';
import TukiIcon from '../common/TukiIcon.astro';
import { HOW_IT_WORKS, BRAND } from '../../lib/constants';
import { TUKI_ICONS } from '../../lib/icons';
---

<section
	id="como-funciona"
	class="relative overflow-hidden border-b border-tuki-purple/8 bg-tuki-lavender py-12 md:py-16"
	aria-labelledby="como-funciona-heading"
>
	<div class="pointer-events-none absolute inset-0" aria-hidden="true">
		<svg
			class="absolute -left-8 top-16 h-40 w-72 text-tuki-purple/20 md:left-8 md:top-20 md:h-48 md:w-96"
			viewBox="0 0 320 160"
			fill="none"
		>
			<path
				d="M8 120 C 80 40, 180 20, 312 48"
				stroke="currentColor"
				stroke-width="2"
				stroke-dasharray="4 8"
				stroke-linecap="round"
			></path>
		</svg>

		<TukiIcon
			src={BRAND.planeIcon}
			alt=""
			size="sm"
			decorative
			class="absolute left-6 top-10 opacity-35 md:left-16 md:top-12"
		/>
		<TukiIcon
			src={TUKI_ICONS.mapa}
			alt=""
			size="sm"
			decorative
			class="absolute bottom-10 right-6 opacity-35 md:right-16 md:bottom-12"
		/>
	</div>

	<Container size="reference" class="relative">
		<div class="mb-3 flex justify-center gap-1.5 text-sm text-tuki-purple/35" aria-hidden="true">
			<span>✦</span>
			<span>✦</span>
			<span>✦</span>
		</div>

		<h2 id="como-funciona-heading" class="tuki-type-title text-center text-tuki-ink">
			Como funciona com a Tuki
		</h2>
		<div class="mx-auto mt-3 h-0.5 w-10 rounded-full bg-tuki-purple" aria-hidden="true"></div>

		<ol class="mt-10 grid gap-6 sm:grid-cols-3 sm:gap-8">
			{
				HOW_IT_WORKS.map((step, index) => (
					<li class="tuki-card-ref relative flex flex-col items-center bg-white px-5 pb-6 pt-10 text-center">
						<span
							class="absolute left-4 top-4 flex h-8 w-8 items-center justify-center rounded-full bg-tuki-purple text-sm font-bold text-white"
							aria-hidden="true"
						>
							{index + 1}
						</span>

						<TukiIcon src={step.icon} alt={step.iconAlt} size="2xl" />

						<h3 class="tuki-type-title mt-5 text-tuki-ink">{step.title}</h3>
						<p class="tuki-type-small mt-2 max-w-[16rem] text-tuki-muted">{step.description}</p>

						<div class="mt-5 h-0.5 w-8 rounded-full bg-tuki-purple/70" aria-hidden="true"></div>
					</li>
				))
			}
		</ol>
	</Container>
</section>
