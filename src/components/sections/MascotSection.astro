---
import Container from '../common/Container.astro';
import Button from '../common/Button.astro';
import TukiIcon from '../common/TukiIcon.astro';
import { SITE, BRAND } from '../../lib/constants';
import { buildWhatsAppUrl } from '../../lib/seo';
---

<section class="relative overflow-hidden tuki-mascot-ref section-padding text-white">
	<Container size="reference" class="relative">
		<div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
			<div class="relative flex justify-center">
				<div class="absolute h-60 w-60 rounded-full bg-tuki-orange/80 blur-sm md:h-72 md:w-72" aria-hidden="true"></div>
				<div class="relative h-72 w-72 md:h-80 md:w-80">
					<span class="tuki-floating-badge absolute -top-2 left-1/2 z-20 flex -translate-x-1/2 -rotate-3 items-center gap-1.5 text-tuki-purple">
						<TukiIcon src={BRAND.planeIcon} alt="" size="xs" decorative />
						Viagem 2026
					</span>
					<div class="flex h-full w-full items-center justify-center overflow-hidden rounded-full border-4 border-white/20 bg-white/5">
						<img
							src={BRAND.mascot.profile}
							alt="Tuki, o tucano viajante"
							class="tuki-mascot-glide h-[102%] w-auto max-w-none translate-y-3 object-contain drop-shadow-2xl"
							width={256}
							height={256}
							loading="lazy"
							decoding="async"
						/>
					</div>
				</div>
			</div>
			<div>
				<h2 class="text-3xl font-extrabold tracking-[-0.03em] md:text-4xl">
					Nosso tucano viajante, pronto pra te <span class="text-tuki-orange">guiar</span>
				</h2>
				<p class="mt-4 text-lg leading-[1.55] text-white/85">
					Com a Tuki, você tem curadoria de verdade, atendimento humano e a tranquilidade de saber que
					cada detalhe da sua viagem está sob controle.
				</p>
				<Button
					href={buildWhatsAppUrl(SITE.phone, 'Olá! Quero viajar com a Tuki!')}
					variant="primary"
					size="lg"
					class="mt-8"
					target="_blank"
					rel="noopener noreferrer"
				>
					Quero viajar com o Tuki
				</Button>
			</div>
		</div>
	</Container>
</section>
