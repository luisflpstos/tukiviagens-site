---
import Container from '../common/Container.astro';
import { TESTIMONIALS } from '../../lib/constants';
---

<section id="depoimentos" class="section-padding bg-gray-50">
	<Container>
		<h2 class="text-center text-3xl font-bold text-gray-900 md:text-4xl">
			Histórias reais de quem voou com o Tuki
		</h2>

		<div class="mt-10 grid gap-6 md:grid-cols-3">
			{
				TESTIMONIALS.map((item) => (
					<article class="rounded-2xl bg-white p-6 shadow-sm">
						<div class="flex gap-1 text-tuki-orange">
							{Array.from({ length: item.rating }).map(() => '★')}
						</div>
						<p class="mt-4 text-gray-700">"{item.text}"</p>
						<div class="mt-6 flex items-center gap-3">
							<div class="flex h-10 w-10 items-center justify-center rounded-full bg-tuki-purple/10 font-semibold text-tuki-purple">
								{item.name.charAt(0)}
							</div>
							<div>
								<p class="font-semibold text-gray-900">{item.name}</p>
								<p class="text-sm text-gray-500">{item.location}</p>
							</div>
						</div>
					</article>
				))
			}
		</div>
	</Container>
</section>
