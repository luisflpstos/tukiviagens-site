---
import Container from '../common/Container.astro';
import SectionEyebrow from '../common/SectionEyebrow.astro';
import { TESTIMONIALS } from '../../lib/constants';
---

<section id="depoimentos" class="section-padding tuki-section-soft">
	<Container size="reference">
		<div class="mx-auto max-w-2xl text-center">
			<SectionEyebrow label="Quem viaja, ama" class="mb-3" />
			<h2 class="text-3xl font-extrabold tracking-[-0.03em] text-tuki-ink md:text-4xl">
				Histórias reais de quem voou com o <span class="text-tuki-purple">Tuki</span>
			</h2>
		</div>

		<div class="mt-10 grid gap-6 md:grid-cols-3">
			{
				TESTIMONIALS.map((item) => (
					<article class="tuki-card-ref flex h-full flex-col bg-white p-6">
						<span class="text-3xl font-extrabold leading-none text-tuki-orange" aria-hidden="true">
							“
						</span>
						<div class="mt-2 flex gap-0.5 text-tuki-orange" aria-label={`${item.rating} estrelas`}>
							{Array.from({ length: item.rating }).map(() => (
								<span aria-hidden="true">★</span>
							))}
						</div>
						<blockquote class="mt-4 flex-1 text-sm leading-relaxed text-tuki-muted">
							"{item.text}"
						</blockquote>
						<div class="mt-6 flex items-center gap-3 border-t border-tuki-purple/8 pt-5">
							<div class="flex h-11 w-11 items-center justify-center rounded-full bg-tuki-purple text-sm font-bold text-white">
								{item.name.charAt(0)}
							</div>
							<div>
								<p class="font-bold text-tuki-ink">{item.name}</p>
								<p class="text-xs text-tuki-muted">{item.location}</p>
							</div>
						</div>
					</article>
				))
			}
		</div>
	</Container>
</section>
