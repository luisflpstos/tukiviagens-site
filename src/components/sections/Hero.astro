---
import Container from '../common/Container.astro';
import Button from '../common/Button.astro';
import StarDecoration from '../common/StarDecoration.astro';
import { SITE, HERO_STATS, BRAND, HERO_EYEBROW, HERO_FLOATING_BADGES, HERO_BACKGROUND } from '../../lib/constants';
import { buildWhatsAppUrl } from '../../lib/seo';
import { HERO_WAVE_PATH, HERO_WAVE_VIEWBOX } from '../../lib/shapes';
---

<section class="relative isolate z-[1000] overflow-hidden text-white">
	<div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
		<img
			src={HERO_BACKGROUND}
			alt=""
			class="tuki-hero-bg-zoom h-full w-full object-cover"
			width={2000}
			height={1200}
			loading="eager"
			decoding="async"
			fetchpriority="high"
		/>
		<div class="tuki-hero-photo-overlay"></div>
		<div class="tuki-hero-ref absolute inset-0"></div>
	</div>

	<StarDecoration size={36} class="tuki-star-twinkle absolute right-6 top-6 z-20 text-tuki-orange md:right-12 md:top-10" />

	<Container size="reference" class="relative pb-24 pt-10 md:pb-28 md:pt-14">
		<div class="grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12">
			<div class="max-w-xl">
				<span
					class="tuki-hero-enter mb-5 inline-flex rounded-full border border-white/25 bg-white/10 px-4 py-1.5 text-[11px] font-bold tracking-[0.12em] text-white/90 uppercase backdrop-blur-sm"
					style="--enter-i: 0"
				>
					{HERO_EYEBROW}
				</span>

				<h1
					class="tuki-hero-enter text-[2rem] font-extrabold leading-[0.98] tracking-[-0.04em] md:text-5xl lg:text-[3.25rem]"
					style="--enter-i: 1"
				>
					O Brasil que você <span class="tuki-heading-accent">sonha</span>,{' '}
					<span class="text-tuki-orange">com a leveza do Tuki.</span>
				</h1>

				<p
					class="tuki-hero-enter mt-5 max-w-lg text-base leading-[1.55] text-white/90 md:text-lg"
					style="--enter-i: 2"
				>
					Hotéis e resorts selecionados a dedo, atendimento humano e pagamento seguro para você viajar
					com leveza.
				</p>

				<div class="tuki-hero-enter mt-7 flex flex-wrap gap-3" style="--enter-i: 3">
					<Button
						href={buildWhatsAppUrl(SITE.phone, 'Olá! Quero planejar minha viagem com a Tuki.')}
						variant="primary"
						size="lg"
						class="gap-2 uppercase tracking-wide"
						target="_blank"
						rel="noopener noreferrer"
					>
						<svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path
								d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
							></path>
						</svg>
						Falar no WhatsApp
					</Button>
					<Button href="/#hoteis" variant="outline" size="lg" class="uppercase tracking-wide">
						Ver hotéis
					</Button>
				</div>

				<dl class="tuki-hero-enter mt-8 grid grid-cols-3 gap-3 border-t border-white/20 pt-6" style="--enter-i: 4">
					{
						HERO_STATS.map((stat) => (
							<div>
								<dt class="text-lg font-extrabold text-tuki-orange md:text-xl">{stat.value}</dt>
								<dd class="mt-0.5 text-[11px] leading-snug text-white/80 md:text-xs">{stat.label}</dd>
							</div>
						))
					}
				</dl>
			</div>

			<div class="tuki-hero-enter relative mx-auto flex w-full max-w-[400px] justify-center lg:max-w-none" style="--enter-i: 3">
				<div
					class="tuki-hero-mascot-ring relative flex aspect-square w-full max-w-[380px] items-center justify-center rounded-full bg-tuki-purple/40 shadow-[0_0_0_16px_color-mix(in_srgb,white_8%,transparent)] backdrop-blur-sm md:max-w-[420px]"
					aria-hidden="true"
				>
					<div class="absolute inset-5 rounded-full border border-white/20"></div>
					
					<img
						src={BRAND.mascot.hero}
						alt="Tuki, o tucano viajante da Tuki Viagens"
						class="tuki-hero-mascot-img relative z-10 mt-6 h-[100%] w-auto object-contain drop-shadow-2xl"
						width={680}
						height={680}
						loading="eager"
						decoding="async"
					/>
				</div>

				{
					HERO_FLOATING_BADGES.map((badge, index) => (
						<span
							class:list={[
								'tuki-badge-float absolute z-20',
								badge.variant === 'white' ? 'tuki-floating-badge' : 'tuki-floating-badge-orange',
								badge.class,
							]}
							style={`--badge-i: ${index}`}
						>
							{badge.text}
						</span>
					))
				}
			</div>
		</div>
	</Container>

	<svg
		class="tuki-hero-bottom-wave pointer-events-none absolute bottom-0 left-0 z-10 block w-full text-tuki-orange"
		viewBox={HERO_WAVE_VIEWBOX}
		preserveAspectRatio="none"
		aria-hidden="true"
	>
		<defs>
			<linearGradient id="tuki-hero-wave-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
				<stop offset="0%" stop-color="var(--color-tuki-orange)"></stop>
				<stop offset="100%" stop-color="color-mix(in srgb, var(--color-tuki-orange) 85%, white)"></stop>
			</linearGradient>
		</defs>
		<path fill="url(#tuki-hero-wave-gradient)" d={HERO_WAVE_PATH}></path>
	</svg>
</section>
