---
import Container from '../common/Container.astro';
import Button from '../common/Button.astro';
import { SITE, HERO_STATS } from '../../lib/constants';
import { buildWhatsAppUrl } from '../../lib/seo';
---

<section class="relative overflow-hidden bg-tuki-purple text-white">
	<div class="absolute inset-0 opacity-20">
		<div class="absolute -right-20 -top-20 h-96 w-96 rounded-full bg-tuki-orange blur-3xl"></div>
		<div class="absolute -bottom-20 -left-20 h-96 w-96 rounded-full bg-tuki-purple-light blur-3xl"></div>
	</div>

	<Container class="relative section-padding">
		<div class="grid items-center gap-12 lg:grid-cols-2">
			<div>
				<h1 class="text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
					{SITE.tagline}
				</h1>
				<p class="mt-6 text-lg text-white/80 md:text-xl">
					Hotéis e resorts selecionados a dedo, atendimento humano e pagamento seguro para você viajar
					com leveza.
				</p>
				<div class="mt-8 flex flex-wrap gap-4">
					<Button href="/#hoteis" variant="primary" size="lg">Escolher viagem</Button>
					<Button
						href={buildWhatsAppUrl(SITE.phone, 'Olá! Tenho uma dúvida sobre viagens com a Tuki.')}
						variant="outline"
						size="lg"
					>
						Tirar minha dúvida
					</Button>
				</div>
				<dl class="mt-10 grid grid-cols-3 gap-4">
					{
						HERO_STATS.map((stat) => (
							<div>
								<dt class="text-2xl font-bold text-tuki-orange md:text-3xl">{stat.value}</dt>
								<dd class="mt-1 text-sm text-white/70">{stat.label}</dd>
							</div>
						))
					}
				</dl>
			</div>

			<div class="relative flex justify-center">
				<div class="relative flex h-72 w-72 items-center justify-center rounded-full bg-white/10 backdrop-blur-sm md:h-96 md:w-96">
					<div class="text-center">
						<p class="text-6xl">🦜</p>
						<p class="mt-4 text-xl font-bold">{SITE.name}</p>
						<p class="text-sm text-white/70">Seu tucano viajante</p>
					</div>
					<span class="absolute -right-2 top-8 rounded-full bg-tuki-orange px-3 py-1 text-xs font-semibold">
						Rio
					</span>
					<span class="absolute -left-2 bottom-12 rounded-full bg-white/20 px-3 py-1 text-xs font-semibold backdrop-blur">
						Segurança
					</span>
				</div>
			</div>
		</div>
	</Container>

	<div class="bg-tuki-orange py-3">
		<div class="animate-pulse overflow-hidden whitespace-nowrap text-center text-sm font-medium text-white">
			PRAIAS PARADISÍACAS • RESORTS ALL-INCLUSIVE • ATENDIMENTO HUMANO • PAGAMENTO SEGURO • CURADORIA TUKI •
		</div>
	</div>
</section>
