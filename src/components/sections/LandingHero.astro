---
import Container from '../common/Container.astro';
import Button from '../common/Button.astro';

interface Props {
	headline: string;
	subheadline?: string;
	cta: string;
	ctaHref?: string;
	campaign?: string;
}

const { headline, subheadline, cta, ctaHref = '#formulario' } = Astro.props;
---

<section class="relative overflow-hidden bg-tuki-purple text-white">
	<Container class="section-padding">
		<div class="mx-auto max-w-3xl text-center">
			<h1 class="text-3xl font-bold md:text-5xl">{headline}</h1>
			{subheadline && <p class="mt-4 text-lg text-white/80 md:text-xl">{subheadline}</p>}
			<Button href={ctaHref} variant="primary" size="lg" class="mt-8">
				{cta}
			</Button>
		</div>
	</Container>
</section>
