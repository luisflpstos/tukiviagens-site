---
import Container from '../common/Container.astro';
import TukiIcon from '../common/TukiIcon.astro';
import StarDecoration from '../common/StarDecoration.astro';
import { WHY_TUKI_BENEFITS, WHY_TUKI_CARDS, WHY_TUKI_INTRO, TRUST_ITEMS } from '../../lib/constants';
---

<section id="por-que-tuki" class="relative section-padding overflow-hidden bg-white">
	<StarDecoration
		size={156}
		class="pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 text-tuki-orange/15"
	/>

	<Container size="reference" class="relative">
		<div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
			<div>
				<h2 class="text-3xl font-extrabold leading-tight tracking-[-0.03em] text-tuki-ink md:text-4xl">
					A leveza de viajar sabendo que <span class="tuki-highlight-block">tudo está sob controle.</span>
				</h2>
				<p class="mt-5 max-w-prose text-base leading-relaxed text-tuki-muted">{WHY_TUKI_INTRO}</p>

				<ul class="mt-8 space-y-4">
					{
						WHY_TUKI_BENEFITS.map((benefit) => (
							<li class="flex items-start gap-3">
								<span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-tuki-orange text-xs font-bold text-white">
									✓
								</span>
								<span class="text-tuki-muted">{benefit}</span>
							</li>
						))
					}
				</ul>

				<div class="mt-8 grid gap-3 sm:grid-cols-2">
					{
						TRUST_ITEMS.map((item) => (
							<div class="tuki-trust-pill flex items-start gap-3 bg-tuki-lavender/50 p-4">
								<TukiIcon src={item.icon} alt={item.iconAlt} size="sm" class="shrink-0" />
								<div>
									<p class="text-sm font-bold text-tuki-ink">{item.title}</p>
									<p class="mt-0.5 text-xs leading-relaxed text-tuki-muted">{item.description}</p>
								</div>
							</div>
						))
					}
				</div>
			</div>

			<div class="grid gap-4 sm:grid-cols-2">
				{
					WHY_TUKI_CARDS.map((card) => (
						<div class="tuki-card-ref bg-white p-5 transition hover:-translate-y-0.5 hover:shadow-md">
							<div class="mb-4 flex h-19 w-19 items-center justify-center rounded-xl bg-tuki-lavender/80 p-1.5">
								<TukiIcon src={card.icon} alt={card.iconAlt} size="md" />
							</div>
							<h3 class="font-bold text-tuki-ink">{card.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-tuki-muted">{card.description}</p>
						</div>
					))
				}
			</div>
		</div>
	</Container>
</section>
