---
import Container from '../common/Container.astro';
import { TRUST_ITEMS } from '../../lib/constants';
---

<section class="border-b border-gray-100 bg-white py-10">
	<Container>
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
			{
				TRUST_ITEMS.map((item) => (
					<div class="flex items-start gap-3 rounded-2xl p-4">
						<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-tuki-purple/10 text-lg">
							✓
						</span>
						<div>
							<h3 class="font-semibold text-gray-900">{item.title}</h3>
							<p class="mt-1 text-sm text-gray-600">{item.description}</p>
						</div>
					</div>
				))
			}
		</div>
	</Container>
</section>
