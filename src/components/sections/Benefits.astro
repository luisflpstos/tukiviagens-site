---
import Container from '../common/Container.astro';
import TukiIcon from '../common/TukiIcon.astro';
import { TRUST_ITEMS } from '../../lib/constants';
---

<section class="relative z-10 -mt-6 bg-tuki-off-white pb-2 pt-0 md:-mt-8">
	<Container size="reference">
		<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{
				TRUST_ITEMS.map((item, index) => (
					<div class="tuki-trust-pill flex items-start gap-3 bg-white p-4 md:p-5">
						<div
							class:list={[
								'flex h-16 w-16 shrink-0 items-center justify-center rounded-xl p-1',
								index % 2 === 0 ? 'bg-tuki-lavender/80' : 'bg-tuki-orange/10',
							]}
						>
							<TukiIcon src={item.icon} alt={item.iconAlt} size="sm" />
						</div>
						<div>
							<h3 class="text-sm font-bold text-tuki-ink">{item.title}</h3>
							<p class="mt-1 text-xs leading-relaxed text-tuki-muted">{item.description}</p>
						</div>
					</div>
				))
			}
		</div>
	</Container>
</section>
