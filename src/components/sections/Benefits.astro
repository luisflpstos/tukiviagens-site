---
import Container from '../common/Container.astro';
import { TRUST_ITEMS } from '../../lib/constants';
---

<section class="relative z-10 -mt-6 bg-tuki-off-white pb-2 pt-0 md:-mt-8">
	<Container size="reference">
		<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{
				TRUST_ITEMS.map((item, index) => (
					<div class="tuki-trust-pill flex items-start gap-3 bg-white p-4 md:p-5">
						<span
							class:list={[
								'flex h-11 w-11 shrink-0 items-center justify-center rounded-xl text-white',
								index % 2 === 0 ? 'bg-tuki-purple' : 'bg-tuki-orange',
							]}
							aria-hidden="true"
						>
							{index === 0 && (
								<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
								</svg>
							)}
							{index === 1 && (
								<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
								</svg>
							)}
							{index === 2 && (
								<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
								</svg>
							)}
							{index === 3 && (
								<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
								</svg>
							)}
						</span>
						<div>
							<h3 class="text-sm font-bold text-tuki-ink">{item.title}</h3>
							<p class="mt-1 text-xs leading-relaxed text-tuki-muted">{item.description}</p>
						</div>
					</div>
				))
			}
		</div>
	</Container>
</section>
