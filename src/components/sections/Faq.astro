---
import Container from '../common/Container.astro';

interface FaqItem {
	question: string;
	answer: string;
}

interface Props {
	items: FaqItem[];
	title?: string;
}

const { items, title = 'Perguntas frequentes' } = Astro.props;
---

{
	items.length > 0 && (
		<section class="section-padding bg-gray-50">
			<Container size="narrow">
				<h2 class="text-2xl font-bold text-gray-900">{title}</h2>
				<div class="mt-8 space-y-4">
					{items.map((item) => (
						<details class="group rounded-2xl bg-white p-5 shadow-sm">
							<summary class="cursor-pointer list-none font-semibold text-gray-900 marker:content-none">
								{item.question}
							</summary>
							<p class="mt-3 text-gray-600">{item.answer}</p>
						</details>
					))}
				</div>
			</Container>
		</section>
	)
}
