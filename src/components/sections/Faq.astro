---
import Container from '../common/Container.astro';

interface FaqItem {
	question: string;
	answer: string;
}

interface Props {
	items: FaqItem[];
	title?: string;
}

const { items, title = 'Perguntas frequentes' } = Astro.props;
---

{
	items.length > 0 && (
		<section class="section-padding tuki-section-lavender">
			<Container size="narrow">
				<h2 class="tuki-type-headline text-tuki-ink">{title}</h2>
				<div class="mt-8 space-y-4">
					{items.map((item) => (
						<details class="tuki-card-ref group bg-white p-5">
							<summary class="tuki-type-title cursor-pointer list-none text-tuki-ink marker:content-none">
								{item.question}
							</summary>
							<p class="tuki-type-body mt-3 text-tuki-muted">{item.answer}</p>
						</details>
					))}
				</div>
			</Container>
		</section>
	)
}
