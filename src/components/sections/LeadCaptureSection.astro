---
import Container from '../common/Container.astro';
import LeadForm from '../common/LeadForm.astro';

interface Props {
	title?: string;
	subtitle?: string;
	formId?: string;
	hotel?: string;
	resort?: string;
	destination?: string;
	campaign?: string;
}

const {
	title = 'Consulte disponibilidade',
	subtitle = 'Preencha o formulário e nossa equipe retorna rapidamente.',
	formId = 'lead-capture-form',
	hotel,
	resort,
	destination,
	campaign,
} = Astro.props;
---

<section class="section-padding bg-white">
	<Container size="narrow">
		<div class="tuki-surface-panel">
			<h2 class="tuki-type-headline text-tuki-ink">{title}</h2>
			<p class="tuki-type-body mt-2 text-tuki-muted">{subtitle}</p>
			<div class="mt-8">
				<LeadForm
					formId={formId}
					hotel={hotel}
					resort={resort}
					destination={destination}
					campaign={campaign}
					submitLabel="Consultar disponibilidade"
				/>
			</div>
		</div>
	</Container>
</section>
