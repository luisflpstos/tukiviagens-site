---
import Container from '../common/Container.astro';
import Button from '../common/Button.astro';
import { SITE } from '../../lib/constants';
import { buildWhatsAppUrl } from '../../lib/seo';

interface Props {
	title?: string;
	subtitle?: string;
}

const {
	title = 'Pronto pra próxima aventura?',
	subtitle = 'Fale com a Tuki e encontre o hotel ou resort perfeito para sua viagem.',
} = Astro.props;
---

<section class="section-padding">
	<Container>
		<div class="tuki-gradient-purple rounded-3xl px-8 py-12 text-center text-white md:px-16 md:py-16">
			<h2 class="text-3xl font-bold md:text-4xl">{title}</h2>
			<p class="mx-auto mt-4 max-w-xl text-lg text-white/80">{subtitle}</p>
			<div class="mt-8 flex flex-wrap justify-center gap-4">
				<Button
					href={buildWhatsAppUrl(SITE.phone, 'Olá! Estou pronto para minha próxima aventura com a Tuki!')}
					variant="primary"
					size="lg"
				>
					Falar com o Tuki
				</Button>
				<Button href={`mailto:${SITE.email}`} variant="outline" size="lg">
					{SITE.email}
				</Button>
			</div>
		</div>
	</Container>
</section>
