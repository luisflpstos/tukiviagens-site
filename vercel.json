{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/destinos/olimpia",
      "destination": "/olimpia/",
      "permanent": true
    },
    {
      "source": "/destinos/olimpia/",
      "destination": "/olimpia/",
      "permanent": true
    }
  ]
}
